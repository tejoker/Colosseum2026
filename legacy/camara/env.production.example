# SauronID CAMARA API - production environment template
# Copy values into your deployment secret manager (do not commit secrets).

# Required integrations
CARD_IDENTITY_RESOLVER_URL=https://card-resolver.your-company.com
KYC_RELAY_URL=https://kyc-relay.your-company.com

# Optional auth
CARD_IDENTITY_RESOLVER_API_KEY=
KYC_RELAY_API_KEY=

# CAMARA operator config
CAMARA_OPERATOR_BASE_URL=https://operator-api.your-camara-partner.com
CAMARA_API_PORT=8004

# Optional issuer tuning
# TIER2_ISSUER_DID=did:sauron:tier2-issuer:1
# TIER2_ISSUER_SEED=replace-with-secret-seed
