# SauronID environment configuration.
# Copy to `.env` and fill in your operator-managed values.
#
# Default mode (development): only ENV=development + SAURON_ADMIN_KEY needed.
# Production: every section below is relevant — read docs/operations.md.

# ───────────────────────────────────────────────────────────
# 1. Core secrets — generate with `openssl rand -hex 32`
# ───────────────────────────────────────────────────────────
# Production checklist
# ENV=production
# SAURON_ADMIN_KEY=replace-with-32-byte-random
# SAURON_TOKEN_SECRET=replace-with-32-byte-random
# SAURON_JWT_SECRET=replace-with-32-byte-random
# SAURON_OPRF_SEED=replace-with-32-byte-random
# SAURON_ALLOWED_ORIGINS=https://app.example.com,https://api.example.com
# SAURON_REQUIRE_CALL_SIG=1                  # fail-closed on missing per-call sigs
# SAURON_REQUIRE_AGENT_TYPE=1                # reject legacy operator-supplied checksum

# Development defaults — used by quickstart.sh
ENV=development
# REQUIRED — generate with openssl rand -hex 32
SAURON_ADMIN_KEY=replace-with-32-byte-random
DATABASE_PATH=./sauron.db

# ───────────────────────────────────────────────────────────
# 2. Network
# ───────────────────────────────────────────────────────────
# PORT=3001
# SAURON_CORE_URL=https://sauronid.example.com

# ───────────────────────────────────────────────────────────
# 3. Feature flags — turn off legacy surface for pure agent-binding deployments
# ───────────────────────────────────────────────────────────
# SAURON_DISABLE_BANK_KYC=1
# SAURON_DISABLE_USER_KYC=1
# SAURON_DISABLE_ZKP=1
# SAURON_DISABLE_COMPLIANCE=1

# ───────────────────────────────────────────────────────────
# 4. On-chain anchoring (Bitcoin OpenTimestamps + Solana Memo)
# ───────────────────────────────────────────────────────────
SAURON_BITCOIN_ANCHOR_PROVIDER=mock
# Production: SAURON_BITCOIN_ANCHOR_PROVIDER=opentimestamps
# SAURON_OTS_CALENDARS=https://alice.btc.calendar.opentimestamps.org,https://bob.btc.calendar.opentimestamps.org
SAURON_BITCOIN_NETWORK=regtest-mock

# Solana — devnet free, mainnet requires funded keypair
# SAURON_SOLANA_ENABLED=1
# SAURON_SOLANA_RPC_URL=https://api.devnet.solana.com
# SAURON_SOLANA_NETWORK=devnet
# SAURON_SOLANA_KEYPAIR_PATH=/etc/sauronid/solana-keypair.json
# SAURON_SOLANA_MEMO_PREFIX=sauronid:v1:

# Anchor batch interval (default 600s)
# SAURON_ACTION_ANCHOR_INTERVAL_SECS=600

# ───────────────────────────────────────────────────────────
# 5. Database backend
# ───────────────────────────────────────────────────────────
# SAURON_DB_BACKEND=sqlite                          # sqlite (default) | postgres
# DATABASE_URL=postgres://sauronid:dev@localhost:5432/sauronid
# SAURON_PG_POOL_SIZE=16
# SAURON_ACCEPT_SINGLE_NODE_SQLITE=1                # acknowledge single-node SQLite in production

# ───────────────────────────────────────────────────────────
# 6. Secret backends — protect root secrets at rest
# ───────────────────────────────────────────────────────────
# SAURON_VAULT_TRANSIT_ENABLED=1
# SAURON_VAULT_ADDR=https://vault.example.com:8200
# SAURON_VAULT_TOKEN=hvs....
# SAURON_VAULT_TRANSIT_KEY=sauronid-root
# SAURON_TOKEN_SECRET_WRAPPED=vault:v1:...
# SAURON_JWT_SECRET_WRAPPED=vault:v1:...
# SAURON_OPRF_SEED_WRAPPED=vault:v1:...
# SAURON_ADMIN_KEY_WRAPPED=vault:v1:...

# AWS KMS path (alternative to Vault)
# SAURON_AWS_KMS_ENABLED=1
# SAURON_AWS_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/...
# AWS_REGION=us-east-1

# ───────────────────────────────────────────────────────────
# 7. ZKP issuer service — optional add-on
# ───────────────────────────────────────────────────────────
SAURON_ISSUER_URL=http://localhost:4000
ISSUER_SEED=change-me-to-a-long-random-issuer-seed
ISSUER_DID=did:sauron:issuer:1

# ───────────────────────────────────────────────────────────
# 8. Telemetry
# ───────────────────────────────────────────────────────────
# RUST_LOG=info,sauron_core=debug
# SAURON_LOG_FORMAT=json                            # pretty (default) | json

# ───────────────────────────────────────────────────────────
# 9. Rate limits — sliding-window counters per agent / per human
# ───────────────────────────────────────────────────────────
# SAURON_RISK_WINDOW_SECS=60
# SAURON_RISK_AGENT_REGISTER_PER_WINDOW=60
#   Default: 60/window in dev, 20/window in production. Set explicitly to
#   override (e.g. 200 for high-volume issuers, or 0 to disable — operators
#   only). Window unit is SAURON_RISK_WINDOW_SECS (60s default).
# SAURON_RISK_AGENT_VERIFY_PER_WINDOW=300
# SAURON_RISK_KYC_RETRIEVE_PER_WINDOW=120
# SAURON_RISK_AGENT_KYC_CONSENT_PER_WINDOW=60
# SAURON_RISK_PAYMENT_AUTHORIZE_PER_WINDOW=30

# Per-call sig skew window
# SAURON_CALL_SIG_SKEW_MS=60000

# ───────────────────────────────────────────────────────────
# 10. Background GC
# ───────────────────────────────────────────────────────────
# SAURON_GC_INTERVAL_SECS=300
# SAURON_GC_REQUESTS_LOG_RETENTION_DAYS=90

# ───────────────────────────────────────────────────────────
# 11. Forward proxy (egress enforcement)
# ───────────────────────────────────────────────────────────
# SAURON_EGRESS_PROXY_ENABLED=1
# SAURON_EGRESS_PROXY_PORT=3010

# ───────────────────────────────────────────────────────────
# 12. Optional: Partner portal / dashboard
# ───────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
SAURON_CORE_INTERNAL_URL=http://localhost:3001
SAURONID_ADMIN_PROXY_TOKEN=change-me-to-a-long-random-dashboard-proxy-token
# Backwards-compat alias (one release): TRUSTAI_ADMIN_PROXY_TOKEN

# ───────────────────────────────────────────────────────────
# 13. Optional: real-agent stress harness (kya-redteam)
# ───────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# REAL_AGENT_STRESS_ITERATIONS=3
# REAL_AGENT_STRESS_CONCURRENCY=2
# REAL_AGENT_TAVILY_MAX_CALLS=3

# ───────────────────────────────────────────────────────────
# 14. /demo Real LLM call — provider API keys (optional)
# ───────────────────────────────────────────────────────────
# Setting any of these means the REAL.LLM.CALL card on /demo can
# use that provider WITHOUT pasting a key in the browser. The
# /api/live/demo/llm-providers endpoint reports which keys are
# present so the UI shows a "KEY FROM .ENV" badge and lets you
# leave the API key field blank.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
# MISTRAL_API_KEY=...
# DEEPSEEK_API_KEY=sk-...
# QWEN_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# TOGETHER_API_KEY=...
# TAVILY_API_KEY=tvly-...
